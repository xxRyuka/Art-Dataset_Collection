# Art Dataset Collector — Environment Variables
# Bu dosyayı kopyala: cp .env .env
# .env dosyasını asla Git'e commit etme!

# ── PostgreSQL Bağlantısı ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=root
DB_NAME=art_dataset

# ── Google Drive ───────────────────────────────────────────────
# Drive'daki ana klasörün ID'si (URL'den alınır: drive.google.com/drive/folders/BU_KISIM)
GOOGLE_DRIVE_FOLDER_ID=1HXKPGcEjvAbdKvieWBB7r1dIFPqNQCXJ

# Google API Key — Drive API için (credentials.json GEREKMEZ, klasör zaten herkese açık)
# Almak için: console.cloud.google.com → APIs & Services → Credentials → Create → API Key
GOOGLE_API_KEY=AIzaSyC_MhE8TVaThAj5oOWpKVvmPuzfVeTtHZo

# ── Güvenlik ───────────────────────────────────────────────────
# Her API isteğinde Header olarak gönderilecek: X-API-Key: bu_değer
API_KEY=change_this_to_a_strong_random_string

# ── Sunucu ────────────────────────────────────────────────────
# GIN_MODE: "debug" (geliştirme) veya "release" (production)
PORT=8080
GIN_MODE=debug


